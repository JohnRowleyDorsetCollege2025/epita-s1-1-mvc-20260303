@model IEnumerable<ProductSummaryViewModel>

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Products</h1>
    <a asp-action="Create" class="btn btn-primary">+ New Product</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No products yet. <a asp-action="Create">Add one</a>.</div>
}
else
{
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th class="text-end">Unit Price</th>
                <th class="text-center">Used in Lines</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Name</td>
                    <td class="text-end">£@p.UnitPrice.ToString("N2")</td>
                    <td class="text-center">@p.UsageCount</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">View</a>
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
