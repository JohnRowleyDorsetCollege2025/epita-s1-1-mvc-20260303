@model CustomerSummaryViewModel

@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <h1>@Model.Name</h1>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-2">Customer ID</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Invoices</dt>
    <dd class="col-sm-10">
        @if (Model.InvoiceCount > 0)
        {
            <a asp-action="Invoices" asp-route-id="@Model.Id">
                View @Model.InvoiceCount invoice(s)
            </a>
        }
        else
        {
            <span class="text-muted">No invoices yet</span>
        }
    </dd>
</dl>
