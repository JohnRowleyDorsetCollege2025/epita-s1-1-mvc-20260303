@model CustomerDeleteViewModel

@{
    ViewData["Title"] = $"Delete — {Model.Name}";
}

<h1>Delete Customer</h1>

@if (Model.CanDelete)
{
    <div class="alert alert-danger">
        Are you sure you want to permanently delete <strong>@Model.Name</strong>?
    </div>
}
else
{
    <div class="alert alert-warning">
        <strong>@Model.Name</strong> has @Model.InvoiceCount invoice(s) and cannot be deleted.
        Please delete or reassign all invoices first.
    </div>
}

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<dl class="row mb-4">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Invoices</dt>
    <dd class="col-sm-10">@Model.InvoiceCount</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" name="id" value="@Model.Id" />

    @if (Model.CanDelete)
    {
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
    }

    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary ms-2">Back</a>
</form>
